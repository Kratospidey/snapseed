{
  "name": "snapbrain",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "node ./scripts/run-expo.mjs start",
    "start:go": "node ./scripts/run-expo.mjs start --go",
    "start:tunnel": "node ./scripts/run-expo.mjs start --go --tunnel",
    "start:clear": "node ./scripts/run-expo.mjs start --clear",
    "android": "node ./scripts/run-expo.mjs start --android",
    "ios": "node ./scripts/run-expo.mjs start --ios",
    "web": "node ./scripts/run-expo.mjs start --web",
    "start:web": "node ./scripts/run-expo.mjs start --web",
    "lint": "node ./scripts/run-expo.mjs lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:web-routes": "jest --config jest.web.config.js --runInBand",
    "test:watch": "jest --watch",
    "doctor": "expo-doctor",
    "web:check": "node ./scripts/run-expo.mjs export --platform web --output-dir /tmp/snapbrain-web-export",
    "validate": "npm run typecheck && npm run lint && npm run test && npm run test:web-routes && npm run web:check"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-community/datetimepicker": "^8.4.4",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-media-library": "~18.2.1",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "zod": "^4.1.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "expo-doctor": "^1.18.10",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  }
}
